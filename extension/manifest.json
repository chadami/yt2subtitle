{
  "manifest_version": 3,
  "name": "YouTube AI Subtitle",
  "version": "0.1.0",
  "description": "Generate and load AI-translated subtitles for YouTube videos.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://www.youtube.com/*", "https://*.onrender.com/*", "https://subtitle.invisiblewind.cn/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Subtitles",
    "default_icon": "icon.svg"
  },
  "icons": {
    "128": "icon.svg"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
